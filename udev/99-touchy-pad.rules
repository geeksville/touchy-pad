# Touchy-Pad — give regular users access to the custom vendor USB interface.
#
# The device enumerates as VID:PID 0x303A:0x8369 with three interfaces:
#   * HID mouse  — kernel-owned, no udev rule needed.
#   * CDC-ACM    — kernel-owned (/dev/ttyACM*), uses the dialout group.
#   * Vendor 0xFF (host_api command/response) — accessed via libusb directly,
#                                                hence needs this rule.
#
# Install:
#   sudo cp bin/99-touchy-pad.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules && sudo udevadm trigger
#   (then re-plug the device, or for the current session run:
#    sudo chgrp plugdev /dev/bus/usb/$BUS/$DEV && sudo chmod g+rw ...)
#
# Make sure your user is in the plugdev group:
#   sudo usermod -aG plugdev "$USER"   # then log out / log back in

# Our assigned PID from espressive
SUBSYSTEM=="usb", ATTRS{idVendor}=="303a", ATTRS{idProduct}=="8369", OWNER="1000", MODE="0660", GROUP="plugdev", TAG+="uaccess"

# when esp32s3 is in bootloader:
SUBSYSTEM=="usb", ATTRS{idVendor}=="303a", ATTRS{idProduct}=="1001", OWNER="1000", MODE="0660", GROUP="plugdev", TAG+="uaccess", ENV{ID_MM_DEVICE_IGNORE}="1", ENV{ID_MM_PORT_IGNORE}="1"

# A common ID used for ch341 uarts (used on some ESP32 boards)
SUBSYSTEM=="usb", ATTRS{idVendor}=="1a86", ATTRS{idProduct}=="7523", OWNER="1000", MODE="0660", GROUP="plugdev", TAG+="uaccess", ENV{ID_MM_DEVICE_IGNORE}="1", ENV{ID_MM_PORT_IGNORE}="1"

