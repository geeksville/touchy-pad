{
  "active": {
    "version": "CURRENT",
    "layoutFlex": {
      "flow": "COLUMN",
      "gap": 8,
      "layout": {
        "children": [
          {
            "id": "setup_hint",
            "styles": [
              {
                "textColor": 16777215
              }
            ],
            "growX": 1,
            "label": {
              "text": "Run 'touchy init' to set up",
              "textAlign": "CENTER"
            }
          },
          {
            "id": "pad_container",
            "growX": 1,
            "growY": 1,
            "layoutGrid": {
              "cols": 1,
              "rows": 1,
              "layout": {
                "children": [
                  {
                    "id": "pad_bg",
                    "styles": [
                      {
                        "bgColor": 1710638,
                        "radius": 16
                      }
                    ],
                    "cell": {},
                    "growX": 1,
                    "growY": 1,
                    "spacer": {}
                  },
                  {
                    "id": "pad_hint",
                    "styles": [
                      {
                        "textColor": 3359846
                      }
                    ],
                    "cell": {},
                    "label": {
                      "text": "Touch here",
                      "fontSize": 30
                    }
                  },
                  {
                    "id": "pad",
                    "cell": {},
                    "growX": 1,
                    "growY": 1,
                    "trackpad": {
                      "leftTouchColor": 49151,
                      "rightTouchColor": 16753920,
                      "middleTouchColor": 16729343,
                      "touchRipple": {
                        "startOpa": 180,
                        "maxRadius": 45,
                        "durationMs": 400,
                        "path": "EASE_OUT",
                        "borderWidth": 0
                      },
                      "tapRipple": {
                        "startOpa": 255,
                        "maxRadius": 70,
                        "durationMs": 300,
                        "path": "EASE_OUT",
                        "borderWidth": 4
                      },
                      "scrollbarColor": 11393254
                    }
                  }
                ]
              }
            }
          }
        ]
      }
    }
  }
}
