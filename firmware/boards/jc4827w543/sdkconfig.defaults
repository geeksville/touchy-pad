# SPDX-License-Identifier: Apache-2.0
# Board-specific Kconfig defaults for the JC4827W543 board
# (ESP32-S3 with 4 MB QSPI flash, 8 MB OPI PSRAM).

# ----- Flash (4 MB, QIO @ 80 MHz) -----
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_ESPTOOLPY_FLASHMODE_QIO=y
CONFIG_ESPTOOLPY_FLASHFREQ_80M=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="boards/jc4827w543/partitions.csv"

# ----- PSRAM (8 MB, octal SPI @ 80 MHz) -----
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y
CONFIG_SPIRAM_FETCH_INSTRUCTIONS=y
CONFIG_SPIRAM_RODATA=y
CONFIG_ESP32S3_DATA_CACHE_LINE_64B=y

# ----- LVGL: feed pixels to the NV3041A QSPI panel in big-endian RGB565.
# The panel expects MSB-first 16-bit colour on the wire. LVGL v9 no longer
# has a CONFIG_LV_COLOR_16_SWAP option; the byte swap is performed by the
# flush_cb in boards/jc4827w543/board/display.cpp via lv_draw_sw_rgb565_swap.
