# SPDX-License-Identifier: GPL-3.0-or-later
# Board-specific Kconfig defaults for the MakerFabs MaTouch 4.3"
# Module: ESP32-S3-WROOM-1-N16R8 (16 MB QIO flash, 8 MB OPI PSRAM).

# ----- Flash (16 MB, QIO @ 80 MHz) -----
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_ESPTOOLPY_FLASHMODE_QIO=y
CONFIG_ESPTOOLPY_FLASHFREQ_80M=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions/16M.csv"

# ----- PSRAM (8 MB, octal SPI @ 80 MHz) -----
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y
CONFIG_SPIRAM_FETCH_INSTRUCTIONS=y
CONFIG_SPIRAM_RODATA=y
CONFIG_ESP32S3_DATA_CACHE_LINE_64B=y

# GPIO19/20 are not used by display or touch, so native USB-OTG is available.
# No CONFIG_TOUCHY_PROTO_OVER_SERIAL needed.
